{% extends 'base.html.twig' %}

{% block title %}Passeport index{% endblock %}

{% block body %}
    <h1>Passeport index</h1>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>LibellePass</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for passeport in passeports %}
            <tr>
                <td>{{ passeport.id }}</td>
                <td>{{ passeport.libellePass }}</td>
                <td>
                    <a href="{{ path('passeport_show', {'id': passeport.id}) }}">show</a>
                    <a href="{{ path('passeport_edit', {'id': passeport.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('passeport_new') }}">Create new</a>
{% endblock %}
