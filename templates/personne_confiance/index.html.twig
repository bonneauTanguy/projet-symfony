                <td>{{ personne_confiance.id }}</td>
                <td>{{ personne_confiance.nom }}</td>
                <td>{{ personne_confiance.prenom }}</td>
                <td>{{ personne_confiance.tel }}</td>
                <td>
                    <a href="{{ path('personne_confiance_show', {'id': personne_confiance.id}) }}">show</a>
                    <a href="{{ path('personne_confiance_edit', {'id': personne_confiance.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('personne_confiance_new') }}">Create new</a>
{% endblock %}
