{% extends 'base.html.twig' %}

{% block title %}PersonneConfiance index{% endblock %}

{% block body %}
    <h1>PersonneConfiance index</h1>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Tel</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for personne_confiance in personne_confiances %}
